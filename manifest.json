{
  "manifest_version": 3,
  "name": "Markdown保存",
  "version": "0.1.0",
  "description": "ChatGPT、Claude、note.comのページをMarkdownとして保存します。",
  "permissions": [
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://note.com/*",
    "https://*.note.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Markdownを保存",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "src/popup.html"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://note.com/*",
        "https://*.note.com/*"
      ],
      "js": [
        "src/markdown.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
