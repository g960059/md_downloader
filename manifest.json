{
  "manifest_version": 3,
  "name": "ChatGPT Markdown Downloader",
  "version": "0.1.0",
  "description": "Download the current ChatGPT conversation as Markdown.",
  "permissions": [
    "tabs"
  ],
  "host_permissions": [
    "https://chatgpt.com/*"
  ],
  "action": {
    "default_title": "Download ChatGPT Markdown",
    "default_popup": "src/popup.html"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "src/markdown.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
